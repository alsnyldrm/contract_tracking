APP_NAME=Contract Tracking
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=80
SECRET_KEY=<CHANGE_ME_SECRET_KEY>
SESSION_COOKIE_NAME=ct_session
SESSION_EXPIRE_MINUTES=480
CSRF_COOKIE_NAME=ct_csrf

DB_HOST=10.2.0.31
DB_PORT=5432
DB_NAME=ctracking
DB_USER=ctracking
DB_PASSWORD=<DB_PASSWORD>

TIMEZONE_DEFAULT=Europe/Istanbul
MAX_UPLOAD_SIZE_MB=25
UPLOAD_ROOT=/app/data/documents

LOG_ROOT=/app/logs
LOG_ROTATION_MB=20
LOG_RETENTION_DAYS=30

RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15
